---
import TopNav from '../../components/nav/TopNav.astro';
import WorkflowNav from '../../components/nav/WorkflowNav.astro';
import MobileMenu from '../../components/nav/MobileMenu.astro';
import SearchOverlay from '../../components/nav/SearchOverlay.astro';
import BuildingBlockCard from '../../components/browse/BuildingBlockCard.astro';
import BlockFilterPills from '../../components/browse/BlockFilterPills.astro';
import NoResults from '../../components/browse/NoResults.astro';

// Load all block and quality gate JSONs at build time
const bbModules = import.meta.glob('../../../data/building-blocks/*.json', { eager: true });
const qgModules = import.meta.glob('../../../data/quality-gates/*.json',   { eager: true });
const wfModules = import.meta.glob('../../../data/workflows/*.json',       { eager: true });

// Compute used_in back-references from workflow steps
const usedIn = {};
for (const wf of Object.values(wfModules)) {
  for (const step of wf.steps ?? []) {
    const blockId = step.building_block_id ?? step.quality_gate_id;
    if (!blockId) continue;
    if (!usedIn[blockId]) usedIn[blockId] = [];
    if (!usedIn[blockId].some(w => w.slug === wf.slug)) {
      usedIn[blockId].push({ name: wf.name, slug: wf.slug });
    }
  }
}

// Merge blocks + quality gates into one array, normalising shape
const allBlocks = [
  ...Object.values(bbModules),
  ...Object.values(qgModules),
];

// Sort alphabetically by name
allBlocks.sort((a, b) => a.name.localeCompare(b.name));
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible+Next:ital,wght@0,200..800;1,200..800&family=Lexend:wght@300..700&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.min.js"></script>
  <title>Building Blocks — APS Prompt Gallery</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root {
      --color-bg: #F7F7FF;
      --color-primary: #170a1c;
      --font-heading: 'Lexend', sans-serif;
      --font-body: 'Atkinson Hyperlegible Next', sans-serif;
    }
    body { font-family: var(--font-body); background: var(--color-bg); margin: 0; color: #212529; }
    h1, h2 { font-family: var(--font-heading); }
    a { color: var(--color-primary); }

    .container { max-width: 900px; margin: 0 auto; padding: 0 20px; }
    .page-header { padding: 32px 0 24px; }
    .page-header h1 { margin: 0 0 6px; font-size: 1.6rem; color: var(--color-primary); }
    .page-header p { margin: 0; color: #6c757d; }

    /* Search bar */
    .search-row { position: relative; margin-bottom: 14px; }
    .search-row input {
      width: 100%;
      padding: 9px 14px 9px 38px;
      border: 1px solid #dee2e6;
      border-radius: 8px;
      font-size: 0.9rem;
      background: white;
      font-family: inherit;
    }
    .search-row input:focus { outline: none; border-color: #a78bfa; box-shadow: 0 0 0 3px rgba(167,139,250,0.15); }
    .search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #adb5bd; pointer-events: none; }

    /* Warning banner */
    .warning-banner {
      background: #f0f9ff;
      border-left: 3px solid #0ea5e9;
      border-radius: 6px;
      padding: 10px 14px;
      font-size: 0.85rem;
      color: #0c4a6e;
      margin-bottom: 14px;
      line-height: 1.5;
    }
    .warning-banner a { color: #0369a1; font-weight: 600; }

    .results-count { font-size: 0.85rem; color: #6c757d; margin-bottom: 16px; }

    /* Card grid */
    .block-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      margin-bottom: 48px;
    }
    @media (max-width: 600px) { .block-grid { grid-template-columns: 1fr; } }

    :global(.hidden) { display: none !important; }
  </style>
</head>
<body>
  <TopNav />
  <WorkflowNav />
  <MobileMenu />

  <div class="container">
    <div class="page-header">
      <h1>Building Blocks</h1>
      <p>Standalone prompt components. Use them individually or combine to build your own workflows.</p>
    </div>

    <div class="search-row">
      <span class="search-icon">🔍</span>
      <input
        type="search"
        id="block-search"
        placeholder="Search building blocks…"
        autocomplete="off"
        aria-label="Search building blocks"
      />
    </div>

    <BlockFilterPills />

    <div class="warning-banner">
      Building blocks are the individual prompts inside each workflow. You can use them on their own for a quick result, but workflows add trust guidance, quality gates, and step-by-step structure around each one. <a href="/workflows/">Browse workflows →</a>
    </div>

    <div class="results-count" id="results-count">Showing {allBlocks.length} blocks</div>

    <div class="block-grid" id="block-grid">
      {allBlocks.map((block) => (
        <BuildingBlockCard
          id={block.id}
          name={block.name}
          description={block.description ?? ''}
          block_type={block.block_type ?? 'quality_gate'}
          domains={block.domains ?? []}
          variable_count={(block.variables ?? []).length}
          prompt_template={block.prompt_template ?? ''}
          used_in={usedIn[block.id] ?? []}
          tags={block.tags ?? []}
        />
      ))}
    </div>

    <NoResults />
  </div>

  <script>
    // ── State ─────────────────────────────────────────────────────────────────
    let activeDomain = '';
    let activeTypes = [];
    let fuseInstance = null;
    let fuseMatchIds = null;

    const cards = Array.from(document.querySelectorAll('.bb-card'));
    const countEl  = document.getElementById('results-count');
    const noResults = document.getElementById('no-results');

    // ── Filter logic ──────────────────────────────────────────────────────────
    function applyFilters() {
      let visible = 0;
      cards.forEach(card => {
        // domain values use underscores; space encoding in data-domains relies on this
        const cardDomains = (card.dataset.domains ?? '').split(' ').filter(Boolean);
        const domainMatch = !activeDomain || cardDomains.includes(activeDomain);
        const typeMatch   = activeTypes.length === 0 || activeTypes.includes(card.dataset.blockType ?? '');
        const searchMatch = fuseMatchIds === null || fuseMatchIds.has(card.dataset.id ?? '');
        const show = domainMatch && typeMatch && searchMatch;
        card.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      if (countEl) countEl.textContent = `Showing ${visible} block${visible !== 1 ? 's' : ''}`;
      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    }

    applyFilters();

    // ── Domain pills (radio) ──────────────────────────────────────────────────
    document.querySelectorAll('#domain-pills .pill').forEach(pill => {
      pill.addEventListener('click', () => {
        activeDomain = pill.dataset.domain ?? '';
        document.querySelectorAll('#domain-pills .pill').forEach(p => {
          p.classList.remove('active');
          p.setAttribute('aria-pressed', 'false');
        });
        pill.classList.add('active');
        pill.setAttribute('aria-pressed', 'true');
        applyFilters();
      });
    });

    // ── Type pills (multi-select) ─────────────────────────────────────────────
    document.querySelectorAll('#type-pills .pill').forEach(pill => {
      pill.addEventListener('click', () => {
        const t = pill.dataset.blockType ?? '';
        if (activeTypes.includes(t)) {
          activeTypes = activeTypes.filter(x => x !== t);
          pill.classList.remove('active');
          pill.setAttribute('aria-pressed', 'false');
        } else {
          activeTypes.push(t);
          pill.classList.add('active');
          pill.setAttribute('aria-pressed', 'true');
        }
        applyFilters();
      });
    });

    // ── More filters toggle ───────────────────────────────────────────────────
    document.getElementById('block-filter-toggle')?.addEventListener('click', function() {
      const sec = document.getElementById('block-filter-secondary');
      if (!sec) return;
      sec.classList.toggle('hidden');
      this.textContent = sec.classList.contains('hidden') ? '+ More filters' : '− Fewer filters';
    });

    // ── Card expand / collapse ────────────────────────────────────────────────
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        // Don't collapse when clicking inside the expanded body (prompt, copy, links)
        if (e.target.closest('.expand-body')) return;

        const isOpen = card.classList.contains('open');

        // Close all
        cards.forEach(c => c.classList.remove('open'));

        if (!isOpen) {
          card.classList.add('open');
          setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
        }
      });
    });

    // ── Copy button ───────────────────────────────────────────────────────────
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const pre = btn.closest('.prompt-box')?.querySelector('.prompt-text');
        if (!pre) return;
        try {
          await navigator.clipboard.writeText(pre.textContent?.trim() ?? '');
          btn.textContent = '✓ Copied';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = 'Copy prompt';
            btn.classList.remove('copied');
          }, 2000);
        } catch {
          btn.textContent = 'Copy failed';
          setTimeout(() => { btn.textContent = 'Copy prompt'; }, 2000);
        }
      });
    });

    // ── Fuse.js search ────────────────────────────────────────────────────────
    async function initFuse() {
      if (fuseInstance) return;
      try {
        const res = await fetch('/search-index.json');
        if (!res.ok) throw new Error('fetch failed');
        const data = await res.json();
        // Filter to only block entries for this page's search
        const blockData = data.filter(d => d.type === 'block');
        if (!window.Fuse) return;
        fuseInstance = new window.Fuse(blockData, {
          keys: [
            { name: 'name',         weight: 3 },
            { name: 'search_text',  weight: 1 },
            { name: 'tags',         weight: 2 },
            { name: 'domain_label', weight: 1.5 },
          ],
          threshold: 0.4,
          distance: 100,
          includeScore: true,
          minMatchCharLength: 2,
        });
      } catch (e) {
        console.error('Block search failed to load', e);
      }
    }

    let searchTimer = null;
    document.getElementById('block-search')?.addEventListener('input', function() {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(async () => {
        const query = this.value.trim();
        if (!query) {
          fuseMatchIds = null;
          applyFilters();
          return;
        }
        await initFuse();
        if (!fuseInstance) return;
        const results = fuseInstance.search(query);
        fuseMatchIds = new Set(results.map(r => r.item.id));
        applyFilters();
      }, 150);
    });
  </script>
  <SearchOverlay />
</body>
</html>
