---
import TopNav from '../components/nav/TopNav.astro';
import MobileMenu from '../components/nav/MobileMenu.astro';
import SearchOverlay from '../components/nav/SearchOverlay.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/favicon.ico" />
<title>Workflow Guide — APS Prompt Gallery</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400;1,9..40,500&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#FAF7F2;--bg-warm:#F5F0E8;--bg-code:#1E1E2E;
  --text:#2C2A28;--text-2:#6B6560;--text-m:#9E9790;
  --border:#E5DFD6;--border-l:#EEEBE5;
  --surface:#fff;--surface-w:#FDF9F3;
  --accent:#2A7B9B;--accent-h:#1E6080;--accent-l:#E4F2F7;--accent-m:#5A9DB8;
  --ok:#2D8B55;--ok-l:#E8F5EE;--err:#C93B3B;--err-l:#FDE8E8;
  --a1:#D94F30;--a2:#2A7B9B;--a3:#7B6DAA;--a4:#D4A843;--a5:#2D8B55;
  --sh-sm:0 1px 2px rgba(44,42,40,.05);--sh-md:0 4px 12px rgba(44,42,40,.08);--sh-lg:0 8px 24px rgba(44,42,40,.1);
  --r-sm:8px;--r-md:12px;--r-lg:16px;--r-full:9999px;
  --ease:cubic-bezier(.16,1,.3,1);
  --fd:150ms;--fn:300ms;--fs:500ms;
  --nav-h:52px;
  --site-nav-h:48px;
  --fw:800px;--fw-w:1000px;
  --font-d:'Bricolage Grotesque',Georgia,serif;
  --font-b:'DM Sans',-apple-system,sans-serif;
  --font-m:'JetBrains Mono','Fira Code',monospace;
}
html{scroll-behavior:smooth}
body{font-family:var(--font-b);background:var(--bg);color:var(--text);line-height:1.6;
  background-image:radial-gradient(ellipse at 20% 50%,rgba(42,123,155,.03) 0%,transparent 50%)}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:var(--r-full)}

/* NAV */
.nav{position:fixed;top:var(--site-nav-h);left:0;right:0;height:var(--nav-h);background:rgba(250,247,242,.92);
  backdrop-filter:blur(12px);border-bottom:1px solid var(--border-l);z-index:100}
.progress-bar{position:absolute;top:0;left:0;height:2px;background:var(--accent);width:0%;transition:width .1s linear}
.nav-inner{max-width:var(--fw-w);margin:0 auto;padding:0 24px;height:100%;display:flex;align-items:center;justify-content:space-between}
.nav-title{font-family:var(--font-d);font-weight:700;font-size:.875rem;color:var(--text-2)}
.nav-dots{display:flex;gap:8px;align-items:center}
.nav-dot{width:10px;height:10px;border-radius:50%;border:2px solid var(--text-m);background:transparent;cursor:pointer;
  position:relative;transition:all var(--fn) var(--ease)}
.nav-dot::after{content:attr(data-label);position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);
  background:var(--text);color:#fff;font-size:.7rem;font-family:var(--font-b);white-space:nowrap;
  padding:3px 8px;border-radius:var(--r-sm);opacity:0;pointer-events:none;transition:opacity .15s}
.nav-dot:hover::after{opacity:1}
.nav-dot.active{border-color:var(--accent);box-shadow:0 0 0 3px rgba(42,123,155,.15)}
.nav-dot.active::before{content:'';position:absolute;inset:2px;border-radius:50%;background:var(--accent)}
.nav-dot.visited{background:var(--accent);border-color:var(--accent)}

/* MODULES */
.module{min-height:100dvh;min-height:100vh;
  padding:calc(var(--site-nav-h) + var(--nav-h) + 48px) 24px 64px}
.module-content{max-width:var(--fw);margin:0 auto}
.module-wide{max-width:var(--fw-w)}

/* MODULE HEADER */
.module-header{margin-bottom:40px}
.module-number{font-family:var(--font-d);font-weight:800;font-size:3.75rem;color:var(--accent);opacity:.15;
  display:block;line-height:1;margin-bottom:-8px}
.module-title{font-family:var(--font-d);font-weight:700;font-size:2.25rem;line-height:1.15;color:var(--text)}
.module-subtitle{font-size:1.125rem;color:var(--text-2);margin-top:8px;line-height:1.5}

/* SCREEN */
.screen{margin-bottom:48px}
.screen-heading{font-family:var(--font-d);font-weight:600;font-size:1.25rem;color:var(--text);margin-bottom:12px}

/* ANIMATE IN */
.animate-in{opacity:0;transform:translateY(18px);transition:opacity var(--fs) var(--ease),transform var(--fs) var(--ease)}
.animate-in.visible{opacity:1;transform:translateY(0)}
.stagger-children>.animate-in:nth-child(1){transition-delay:0ms}
.stagger-children>.animate-in:nth-child(2){transition-delay:100ms}
.stagger-children>.animate-in:nth-child(3){transition-delay:200ms}
.stagger-children>.animate-in:nth-child(4){transition-delay:300ms}
.stagger-children>.animate-in:nth-child(5){transition-delay:400ms}
.stagger-children>.animate-in:nth-child(6){transition-delay:500ms}

/* TYPOGRAPHY */
p{line-height:1.7;color:var(--text-2);margin-bottom:12px}
strong{color:var(--text);font-weight:600}

/* CALLOUTS */
.callout{background:var(--accent-l);border-left:3px solid var(--accent);border-radius:var(--r-sm);
  padding:14px 18px;margin:16px 0}
.callout-ok{background:var(--ok-l);border-left-color:var(--ok)}
.callout-warn{background:#FFF8E6;border-left-color:var(--a4)}
.callout strong{color:var(--text)}
.callout p{margin:0;font-size:.9rem}

/* ACTOR CARDS */
.actor-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin:20px 0}
.actor-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-md);
  padding:16px;display:flex;flex-direction:column;gap:8px;box-shadow:var(--sh-sm)}
.actor-icon{font-size:1.75rem;line-height:1}
.actor-name{font-family:var(--font-d);font-weight:700;font-size:.95rem;color:var(--text)}
.actor-desc{font-size:.8rem;color:var(--text-2);line-height:1.5}
.actor-tag{display:inline-block;font-size:.7rem;font-family:var(--font-m);padding:2px 8px;
  border-radius:var(--r-full);margin-top:4px}
.tag-1{background:rgba(217,79,48,.1);color:#A83820}
.tag-2{background:rgba(42,123,155,.1);color:#1E6080}
.tag-3{background:rgba(123,109,170,.1);color:#5A4E8A}
.tag-4{background:rgba(212,168,67,.15);color:#8A6C1A}
.tag-5{background:rgba(45,139,85,.1);color:#1A6B3A}

/* FILE TREE */
.file-tree{background:var(--bg-code);border-radius:var(--r-md);padding:20px;
  font-family:var(--font-m);font-size:.8rem;color:#CDD6F4;line-height:1.9;margin:16px 0}
.ft-dir{color:#89B4FA}
.ft-file{color:#CDD6F4}
.ft-file.ft-json{color:#A6E3A1}
.ft-file.ft-astro{color:#F9E2AF}
.ft-comment{color:#6C7086}
.ft-highlight{color:#FAB387;font-weight:600}

/* TRANSLATION BLOCK */
.translation-block{display:grid;grid-template-columns:1fr 1fr;gap:0;border-radius:var(--r-md);
  overflow:visible;box-shadow:var(--sh-md);margin:20px 0}
.translation-code{background:var(--bg-code);color:#CDD6F4;padding:20px;font-family:var(--font-m);
  font-size:.78rem;line-height:1.8;position:relative;border-radius:var(--r-md) 0 0 var(--r-md);overflow:hidden}
.translation-code pre,.translation-code code{white-space:pre-wrap;word-break:break-word;overflow-x:hidden}
.translation-english{background:var(--surface-w);padding:20px;font-size:.85rem;line-height:1.7;
  border-left:3px solid var(--accent);border-radius:0 var(--r-md) var(--r-md) 0}
.tl-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.1em;font-family:var(--font-m);
  opacity:.5;margin-bottom:8px;display:block}
.tl{margin-bottom:8px;color:var(--text-2);font-size:.82rem;line-height:1.6}
.tl:last-child{margin-bottom:0}
.tl strong{color:var(--a5);font-weight:600}
.tl.tl-key{color:var(--text)}
.tl.tl-edit{color:var(--accent);font-weight:500}

/* SYNTAX HIGHLIGHT */
.ck{color:#CBA6F7}.cs{color:#A6E3A1}.cf{color:#89B4FA}.cc{color:#6C7086}
.cn{color:#FAB387}.cp{color:#F9E2AF}.co{color:#94E2D5}.ct{color:#F38BA8}.ca{color:#F9E2AF}

/* STEP CARDS */
.step-cards{display:flex;flex-direction:column;gap:12px;margin:16px 0}
.step-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-md);
  padding:16px 18px;display:flex;gap:14px;align-items:flex-start;box-shadow:var(--sh-sm)}
.step-num{background:var(--accent);color:#fff;width:28px;height:28px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;font-family:var(--font-d);
  font-weight:700;font-size:.85rem;flex-shrink:0;margin-top:1px}
.step-body{flex:1}
.step-title{font-family:var(--font-d);font-weight:600;font-size:.95rem;color:var(--text);margin-bottom:4px}
.step-text{font-size:.83rem;color:var(--text-2);line-height:1.5}
.step-file{font-family:var(--font-m);font-size:.75rem;color:var(--accent);background:var(--accent-l);
  padding:1px 8px;border-radius:var(--r-full);margin-top:6px;display:inline-block}

/* FIELD CARDS */
.field-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px;margin:16px 0}
.field-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-sm);padding:12px}
.field-name{font-family:var(--font-m);font-size:.78rem;color:var(--accent);margin-bottom:4px}
.field-desc{font-size:.78rem;color:var(--text-2);line-height:1.4}
.field-req{font-size:.65rem;font-family:var(--font-m);padding:1px 6px;border-radius:var(--r-full);
  margin-top:6px;display:inline-block}
.req-y{background:rgba(217,79,48,.1);color:#A83820}
.req-n{background:var(--border-l);color:var(--text-m)}

/* FLOW DIAGRAM */
.flow-row{display:flex;align-items:center;gap:10px;margin:20px 0;flex-wrap:wrap}
.flow-node{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r-sm);
  padding:10px 16px;font-size:.82rem;font-family:var(--font-d);font-weight:600;color:var(--text);
  box-shadow:var(--sh-sm);text-align:center;min-width:100px}
.flow-arrow{color:var(--text-m);font-size:1.2rem;flex-shrink:0}
.flow-node.node-json{border-color:var(--a4);background:#FFFDF0}
.flow-node.node-astro{border-color:var(--a3);background:#F9F7FF}
.flow-node.node-layout{border-color:var(--a2);background:var(--accent-l)}
.flow-node.node-bb{border-color:var(--a5);background:var(--ok-l)}
.flow-node.node-browser{border-color:var(--a1);background:#FFF5F2}

/* GROUP CHAT */
.chat-window{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);
  padding:20px;margin:20px 0;box-shadow:var(--sh-md);min-height:240px}
.chat-header{font-size:.75rem;font-family:var(--font-m);color:var(--text-m);margin-bottom:16px;
  text-align:center;text-transform:uppercase;letter-spacing:.08em}
.chat-msg{display:flex;gap:10px;margin-bottom:14px;opacity:0;transform:translateY(6px);
  transition:opacity .35s,transform .35s}
.chat-msg.appeared{opacity:1;transform:translateY(0)}
.chat-msg.msg-right{flex-direction:row-reverse}
.msg-avatar{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;
  justify-content:center;font-size:1rem;flex-shrink:0;border:1.5px solid var(--border)}
.msg-bubble{background:var(--accent-l);border-radius:12px 12px 12px 3px;padding:9px 13px;
  font-size:.82rem;line-height:1.5;max-width:72%;color:var(--text)}
.msg-right .msg-bubble{background:#F0EBF8;border-radius:12px 12px 3px 12px}
.msg-sender{font-size:.7rem;font-family:var(--font-m);color:var(--text-m);
  margin-bottom:3px;display:block}
.chat-btn{background:var(--accent);color:#fff;border:none;padding:8px 18px;border-radius:var(--r-full);
  font-family:var(--font-b);font-size:.82rem;cursor:pointer;margin-top:10px;
  transition:background var(--fd)}
.chat-btn:hover{background:var(--accent-h)}

/* DATA FLOW ANIMATION */
.dflow{margin:20px 0}
.dflow-step{display:flex;align-items:center;gap:12px;padding:10px 0;
  opacity:.3;transition:opacity .4s,transform .4s;transform:translateX(-8px)}
.dflow-step.active{opacity:1;transform:translateX(0)}
.dflow-dot{width:10px;height:10px;border-radius:50%;background:var(--border);flex-shrink:0;
  transition:background .3s}
.dflow-step.active .dflow-dot{background:var(--accent)}
.dflow-line{width:1px;background:var(--border);margin-left:4px;height:20px;flex-shrink:0}
.dflow-text{font-size:.83rem;line-height:1.4}
.dflow-text strong{color:var(--text);font-size:.82rem}
.dflow-text small{color:var(--text-m);font-size:.74rem;display:block;font-family:var(--font-m)}
.dflow-play{background:var(--surface);border:1.5px solid var(--accent);color:var(--accent);
  padding:7px 16px;border-radius:var(--r-full);font-size:.8rem;cursor:pointer;margin-top:4px;
  font-family:var(--font-b);transition:all var(--fd)}
.dflow-play:hover{background:var(--accent);color:#fff}

/* QUIZ */
.quiz{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);
  padding:22px;margin:24px 0;box-shadow:var(--sh-sm)}
.quiz-label{font-size:.65rem;font-family:var(--font-m);text-transform:uppercase;letter-spacing:.1em;
  color:var(--text-m);margin-bottom:12px;display:block}
.quiz-q{font-family:var(--font-d);font-weight:600;font-size:1rem;color:var(--text);margin-bottom:16px;line-height:1.4}
.quiz-opts{display:flex;flex-direction:column;gap:8px}
.quiz-opt{background:var(--surface-w);border:1.5px solid var(--border);border-radius:var(--r-sm);
  padding:10px 14px;font-size:.85rem;color:var(--text);cursor:pointer;text-align:left;
  transition:all var(--fd);font-family:var(--font-b)}
.quiz-opt:hover:not(:disabled){border-color:var(--accent);background:var(--accent-l)}
.quiz-opt.correct{border-color:var(--ok);background:var(--ok-l);color:#1A6B3A}
.quiz-opt.wrong{border-color:var(--err);background:var(--err-l);color:#A83820}
.quiz-opt:disabled{cursor:default}
.quiz-fb{margin-top:14px;padding:12px;border-radius:var(--r-sm);font-size:.83rem;line-height:1.5;
  display:none}
.quiz-fb.show{display:block}
.quiz-fb.fb-ok{background:var(--ok-l);color:#1A6B3A;border-left:3px solid var(--ok)}
.quiz-fb.fb-err{background:var(--err-l);color:#A83820;border-left:3px solid var(--err)}

/* TOOLTIP */
.tt{border-bottom:1.5px dashed var(--accent);cursor:pointer;color:inherit}
#tooltip-box{position:fixed;background:#1A1A2E;color:#E2E8F0;font-size:.75rem;line-height:1.5;
  padding:8px 12px;border-radius:var(--r-sm);max-width:240px;z-index:9999;pointer-events:none;
  box-shadow:var(--sh-lg);opacity:0;transition:opacity .15s;font-family:var(--font-b)}
#tooltip-box.visible{opacity:1}

/* 2-COL */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:16px 0}

/* BADGE ROW */
.badge-row{display:flex;flex-wrap:wrap;gap:8px;margin:12px 0}
.badge{font-family:var(--font-m);font-size:.72rem;padding:3px 10px;border-radius:var(--r-full)}
.badge-req{background:rgba(217,79,48,.1);color:#A83820}
.badge-opt{background:var(--border-l);color:var(--text-m)}
.badge-auto{background:rgba(42,123,155,.1);color:#1E6080}

/* CHECKLIST */
.checklist{list-style:none;margin:16px 0}
.checklist li{display:flex;gap:10px;padding:8px 0;border-bottom:1px solid var(--border-l);
  font-size:.85rem;color:var(--text-2);align-items:flex-start}
.checklist li:last-child{border-bottom:none}
.check-icon{color:var(--ok);flex-shrink:0;margin-top:1px}
.warn-icon{color:var(--a4);flex-shrink:0;margin-top:1px}

/* DIVIDER */
.divider{height:1px;background:var(--border-l);margin:32px 0}

/* RESPONSIVE */
@media(max-width:680px){
  .translation-block{grid-template-columns:1fr}
  .translation-code{border-radius:var(--r-md) var(--r-md) 0 0}
  .translation-english{border-left:none;border-top:3px solid var(--accent);
    border-radius:0 0 var(--r-md) var(--r-md)}
  .two-col{grid-template-columns:1fr}
  .flow-row{flex-direction:column;align-items:flex-start}
  .flow-arrow{transform:rotate(90deg)}
  .module-title{font-size:1.75rem}
  .actor-grid{grid-template-columns:1fr 1fr}
}
</style>
</head>
<body>

<TopNav />
<MobileMenu />

<div id="tooltip-box"></div>

<!-- NAV -->
<nav class="nav" id="nav">
  <div class="progress-bar" id="progress-bar"></div>
  <div class="nav-inner">
    <span class="nav-title">APS Workflow Guide</span>
    <div class="nav-dots" id="nav-dots">
      <button class="nav-dot" data-target="module-1" data-label="The Big Picture" aria-label="Module 1"></button>
      <button class="nav-dot" data-target="module-2" data-label="Workflow JSON" aria-label="Module 2"></button>
      <button class="nav-dot" data-target="module-3" data-label="Building Blocks" aria-label="Module 3"></button>
      <button class="nav-dot" data-target="module-4" data-label="Adding a Workflow" aria-label="Module 4"></button>
      <button class="nav-dot" data-target="module-5" data-label="Editing Workflows" aria-label="Module 5"></button>
    </div>
  </div>
</nav>

<!-- ═══════════════════════════════════════════════════════
     MODULE 1 — THE BIG PICTURE
═══════════════════════════════════════════════════════ -->
<section class="module" id="module-1" style="background:var(--bg)">
<div class="module-content">

  <header class="module-header animate-in">
    <span class="module-number">01</span>
    <h1 class="module-title">The Big Picture</h1>
    <p class="module-subtitle">What this app actually is, who the cast of characters are, and what happens under the hood when someone opens a workflow.</p>
  </header>

  <!-- Screen 1: What is this app -->
  <section class="screen animate-in">
    <h2 class="screen-heading">What is the APS Prompt Gallery?</h2>
    <p>It's a web app where public servants can find <span class="tt" data-tip="A multi-step AI-assisted process — like a recipe that uses AI at each step — rather than a single one-off prompt.">workflows</span> that walk them through complex tasks using AI. Think of it as a structured recipe book: each recipe (workflow) tells you what to do, in what order, with what AI prompts.</p>
    <p>Behind the scenes, it's a <span class="tt" data-tip="A website where all the HTML files are pre-built at deploy time — no server computing happens when visitors load pages. Fast, cheap, and secure.">static site</span> built with <span class="tt" data-tip="A JavaScript framework for building fast static websites. It pre-builds pages during deployment so visitors get plain HTML files — no waiting for a server.">Astro</span>, hosted on <span class="tt" data-tip="A web hosting platform that automatically rebuilds and redeploys your site every time you push code to GitHub. Free tier works fine for this project.">Netlify</span>, with all content stored in <span class="tt" data-tip="JavaScript Object Notation — a text-based format for storing structured data. It looks like labelled fields in curly braces. Easy to read and edit.">JSON</span> files.</p>

    <div class="actor-grid stagger-children">
      <div class="actor-card animate-in">
        <div class="actor-icon">📋</div>
        <div class="actor-name">Workflow JSON</div>
        <div class="actor-desc">Defines the workflow: its title, steps, required inputs, and which building blocks to use.</div>
        <span class="actor-tag tag-4">data/workflows/</span>
      </div>
      <div class="actor-card animate-in">
        <div class="actor-icon">🧱</div>
        <div class="actor-name">Building Block</div>
        <div class="actor-desc">Contains the actual AI prompt template, with placeholder variables like <code style="font-size:.75rem">{"{{topic}}"}</code>.</div>
        <span class="actor-tag tag-5">data/building-blocks/</span>
      </div>
      <div class="actor-card animate-in">
        <div class="actor-icon">📄</div>
        <div class="actor-name">Astro Page</div>
        <div class="actor-desc">A tiny file that imports the JSON data and hands it to the Layout to render.</div>
        <span class="actor-tag tag-3">src/pages/workflows/</span>
      </div>
      <div class="actor-card animate-in">
        <div class="actor-icon">🏗️</div>
        <div class="actor-name">WorkflowLayout</div>
        <div class="actor-desc">The shared template that turns workflow data into the HTML the user sees. You never edit this for new workflows.</div>
        <span class="actor-tag tag-2">src/layouts/</span>
      </div>
    </div>
  </section>

  <!-- Screen 2: Group Chat — what happens when a page loads -->
  <section class="screen animate-in">
    <h2 class="screen-heading">What happens when someone opens "Briefing Note"?</h2>
