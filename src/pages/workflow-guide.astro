<script is:inline>
(function(){

/* ── TOOLTIP ── */
const tb = document.getElementById('tooltip-box');
document.querySelectorAll('.tt').forEach(el => {
  const tip = el.dataset.tip;
  if (!tip) return;
  function show(e) {
    tb.textContent = tip;
    tb.classList.add('visible');
    move(e);
  }
  function move(e) {
    const x = e.clientX, y = e.clientY;
    const w = tb.offsetWidth || 240;
    const left = Math.min(x + 12, window.innerWidth - w - 12);
    const top = y - tb.offsetHeight - 10 < 0 ? y + 20 : y - tb.offsetHeight - 10;
    tb.style.left = left + 'px';
    tb.style.top = top + 'px';
  }
  function hide() { tb.classList.remove('visible'); }
  el.addEventListener('mouseenter', show);
  el.addEventListener('mousemove', move);
  el.addEventListener('mouseleave', hide);
  el.addEventListener('touchstart', e => {
    show(e.touches[0]);
    setTimeout(hide, 2500);
  }, { passive: true });
});

/* ── PROGRESS BAR + NAV DOTS ── */
const pb = document.getElementById('progress-bar');
const dots = document.querySelectorAll('.nav-dot');
const modules = document.querySelectorAll('.module');

function updateNav() {
  const st = window.scrollY;
  const sh = document.documentElement.scrollHeight - window.innerHeight;
  pb.style.width = (st / sh * 100) + '%';
  let cur = 0;
  modules.forEach((m, i) => {
    const rect = m.getBoundingClientRect();
    if (rect.top <= 100) cur = i;
  });
  dots.forEach((d, i) => {
    d.classList.toggle('active', i === cur);
    if (i < cur) d.classList.add('visited'); else d.classList.remove('visited');
  });
}
window.addEventListener('scroll', () => requestAnimationFrame(updateNav), { passive: true });
updateNav();

dots.forEach(d => {
  d.addEventListener('click', () => {
    document.getElementById(d.dataset.target)?.scrollIntoView({ behavior: 'smooth' });
  });
});

/* ── KEYBOARD NAV ── */
document.addEventListener('keydown', e => {
  if (['INPUT','TEXTAREA'].includes(e.target.tagName)) return;
  const mods = Array.from(modules);
  let cur = 0;
  mods.forEach((m, i) => { if (m.getBoundingClientRect().top <= 60) cur = i; });
  if ((e.key === 'ArrowDown' || e.key === 'ArrowRight') && cur < mods.length - 1) {
    mods[cur + 1].scrollIntoView({ behavior: 'smooth' }); e.preventDefault();
  }
  if ((e.key === 'ArrowUp' || e.key === 'ArrowLeft') && cur > 0) {
    mods[cur - 1].scrollIntoView({ behavior: 'smooth' }); e.preventDefault();
  }
});

/* ── SCROLL REVEAL ── */
const io = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
}, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
document.querySelectorAll('.animate-in').forEach(el => io.observe(el));

/* ── QUIZ ── */
const feedback = {
  q1: {
    ok: "Exactly right. A workflow needs all three: a workflow JSON (metadata + step list), building block JSONs (the actual prompts), and an Astro page (the tiny glue file). WorkflowLayout is shared — you never edit it for new content.",
    err: "Not quite. WorkflowLayout does the rendering work, but it needs to receive data from three separate files you create: a workflow JSON, building block JSONs, and an Astro page that wires them together."
  },
  q2: {
    ok: "Correct. <code>user_action_after</code> in the workflow JSON is exactly the field that produces that 'what to do next' box. It's safe to edit — just plain text, no side effects.",
    err: "Not quite. The 'what to do next' box comes from the <code>user_action_after</code> field on the step in the workflow JSON file. WorkflowLayout reads it; it doesn't define it."
  },
  q3: {
    ok: "Exactly. The variable in the building block template is just a placeholder — what brings it to life is the matching <code>inputs_required</code> entry in the workflow JSON. That's what creates the form field the user fills in.",
    err: "Not quite. The template variable needs a matching <code>name: \"minister_name\"</code> in the workflow JSON's <code>inputs_required</code> array. That's what creates the form field and supplies the value."
  },
  q4: {
    ok: "Correct. Creating the building block file is necessary but not sufficient. The Astro page also needs to import the file and add an entry to the <code>blocks</code> object with the key matching the <code>building_block_id</code> exactly.",
    err: "Not quite. The most likely issue is in the Astro page. You've created the building block file, but the Astro page still needs to (1) import it, and (2) add <code>'BB-MTG-005': importedVar</code> to the <code>blocks</code> object. Without both, WorkflowLayout can't find the prompt."
  },
  q5: {
    ok: "Correct. Maturity is stored entirely in the workflow JSON — three fields to update: <code>maturity</code>, <code>maturity_note</code>, and <code>maturity_updated</code>. The badge on the page and roadmap updates automatically when Netlify rebuilds.",
    err: "Not quite. Maturity is a data field — it lives in the workflow JSON alongside the step definitions. Just open <code>wf-eng-001-stakeholder-analysis.json</code>, update the three maturity fields, and push."
  }
};

window.handleQ = function(optsId, fbId, btn) {
  const qKey = fbId.replace('-fb','');
  const opts = document.getElementById(optsId);
  const fb = document.getElementById(fbId);
  const correct = btn.dataset.correct === 'true';
  opts.querySelectorAll('.quiz-opt').forEach(o => o.disabled = true);
  btn.classList.add(correct ? 'correct' : 'wrong');
  if (!correct) opts.querySelector('[data-correct="true"]')?.classList.add('correct');
  fb.className = 'quiz-fb show ' + (correct ? 'fb-ok' : 'fb-err');
  fb.innerHTML = (correct ? '✓ ' : '✗ ') + (feedback[qKey]?.[correct ? 'ok' : 'err'] || '');
};

/* ── GROUP CHAT ── */
function runChat(chatId) {
  const msgs = document.querySelectorAll('#' + chatId + ' .chat-msg');
  msgs.forEach(m => { m.classList.remove('appeared'); });
  msgs.forEach(m => {
    const delay = parseInt(m.dataset.delay || 0);
    setTimeout(() => m.classList.add('appeared'), delay);
  });
}
document.getElementById('chat-1-replay')?.addEventListener('click', () => runChat('chat-1'));
setTimeout(() => runChat('chat-1'), 600);

/* ── DATA FLOW ANIMATION ── */
function runDflow(prefix, count) {
  const steps = [];
  for (let i = 1; i <= count; i++) steps.push(document.getElementById(prefix + i));
  steps.forEach(s => s?.classList.remove('active'));
  let i = 0;
  function next() {
    if (i < steps.length) { steps[i]?.classList.add('active'); i++; setTimeout(next, 700); }
  }
  next();
}
document.getElementById('dflow-1-btn')?.addEventListener('click', () => runDflow('df-s', 5));

})();
</script>
