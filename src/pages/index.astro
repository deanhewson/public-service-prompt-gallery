<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible+Next:ital,wght@0,200..800;1,200..800&family=Atkinson+Hyperlegible+Mono:wght@400;700&family=Lexend:wght@300..700&display=swap" rel="stylesheet" />
  <title>APS GenAI Prompt Gallery</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    :root {
      --color-primary: #170a1c;
      --color-primary-light: #DFD9E2;
      --color-bg: #F7F7FF;
      --color-surface: #ffffff;
      --color-border: #dee2e6;
      --color-text: #212529;
      --color-muted: #6c757d;
      --radius: 8px;
      --font-heading: 'Lexend', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --font-body: 'Atkinson Hyperlegible Next', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --font-mono: 'Atkinson Hyperlegible Mono', 'Courier New', Courier, monospace;
    }

    body {
      font-family: var(--font-body);
      background: var(--color-bg);
      color: var(--color-text);
      margin: 0;
      line-height: 1.6;
    }

    a { color: var(--color-primary); text-decoration: none; }
    a:hover { text-decoration: underline; }
    h1, h2, h3, h4, h5, h6 { font-family: var(--font-heading); }

    /* ── PoC Banner ──────────────────────────────────── */
    .poc-banner {
      background: #F5EEF3;
      border-bottom: 1px solid #C19AB7;
      font-size: 0.82rem;
      color: #3d1a35;
      padding: 7px 0;
      text-align: center;
    }
    .poc-banner a { color: var(--color-primary); }

    /* ── Nav ─────────────────────────────────────────── */
    .site-header {
      background: var(--color-primary);
      color: white;
      padding: 0 24px;
    }

    .site-nav {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      min-height: 48px;
    }

    .nav-logo {
      color: white;
      font-weight: 700;
      font-size: 0.95rem;
      white-space: nowrap;
      margin-right: 24px;
      padding: 14px 0;
      flex-shrink: 0;
    }
    .nav-logo:hover { text-decoration: none; opacity: 0.9; }

    .nav-links {
      display: flex;
      align-items: stretch;
    }

    .nav-group {
      position: relative;
    }

    .nav-group-trigger {
      background: none;
      border: none;
      border-bottom: 3px solid transparent;
      color: rgba(255,255,255,0.8);
      font-size: 0.85rem;
      font-family: inherit;
      padding: 14px 12px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 5px;
      white-space: nowrap;
      height: 100%;
      transition: color 0.15s, border-color 0.15s;
    }
    .nav-group:hover .nav-group-trigger { color: white; }

    .nav-chevron {
      font-size: 0.65rem;
      transition: transform 0.2s;
      opacity: 0.7;
    }
    .nav-group:hover .nav-chevron { transform: rotate(180deg); }

    .nav-dropdown {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      min-width: 190px;
      background: #2a1432;
      border: 1px solid rgba(255,255,255,0.12);
      border-top: none;
      border-radius: 0 0 var(--radius) var(--radius);
      box-shadow: 0 6px 16px rgba(0,0,0,0.25);
      z-index: 200;
    }
    .nav-group:hover .nav-dropdown { display: block; }

    .nav-dropdown a {
      display: block;
      color: rgba(255,255,255,0.85);
      font-size: 0.85rem;
      padding: 10px 16px;
      white-space: nowrap;
      transition: color 0.1s, background 0.1s;
    }
    .nav-dropdown a:hover { color: white; background: rgba(255,255,255,0.08); text-decoration: none; }

    .nav-link-flat {
      color: rgba(255,255,255,0.8);
      font-size: 0.85rem;
      padding: 14px 12px;
      white-space: nowrap;
      display: flex;
      align-items: center;
    }
    .nav-link-flat:hover { color: white; text-decoration: none; }
    .nav-link-flat-active { color: white; border-bottom: 3px solid white; }

    /* ── Hamburger / mobile menu ─────────────────────── */
    .nav-hamburger {
      display: none;
      background: none;
      border: none;
      color: white;
      font-size: 1.5rem;
      cursor: pointer;
      padding: 8px 4px;
      margin-left: auto;
      line-height: 1;
    }

    .nav-mobile-menu {
      display: none;
      background: #2a1432;
      border-top: 1px solid rgba(255,255,255,0.1);
    }
    .nav-mobile-menu.is-open { display: block; }

    .nav-mobile-group-label {
      color: rgba(255,255,255,0.45);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 12px 20px 4px;
    }
    .nav-mobile-menu a {
      display: block;
      color: rgba(255,255,255,0.85);
      font-size: 0.9rem;
      padding: 12px 20px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      text-decoration: none;
    }
    .nav-mobile-menu a:hover { color: white; background: rgba(255,255,255,0.08); }

    /* ── Container ───────────────────────────────────── */
    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 20px;
    }

    /* ── Hero ────────────────────────────────────────── */
    .hero {
      padding: 48px 0 40px;
    }

    .hero h2 {
      font-size: 1.7rem;
      margin: 0 0 16px;
      line-height: 1.3;
    }

    .hero p {
      font-size: 1rem;
      color: var(--color-muted);
      margin: 0 0 16px;
    }

    .hero-howto {
      margin-top: 20px;
      padding-top: 20px;
      border-top: 1px solid var(--color-border);
    }

    .hero-howto h4 {
      margin: 0 0 14px;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--color-muted);
    }

    .howto-steps {
      display: flex;
      align-items: flex-start;
    }

    .howto-step {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      text-align: center;
    }

    .howto-num {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: var(--color-primary);
      color: white;
      font-size: 0.75rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .howto-step p {
      margin: 0;
      font-size: 0.8rem;
      color: var(--color-muted);
      line-height: 1.45;
    }

    .howto-arrow {
      color: var(--color-border);
      font-size: 1rem;
      flex-shrink: 0;
      padding: 4px 4px 0;
    }

    .security-notice {
      background: var(--color-primary-light);
      border-left: 3px solid var(--color-primary);
      padding: 12px 16px;
      border-radius: 0 var(--radius) var(--radius) 0;
      font-size: 0.875rem;
      margin: 24px 0 0;
    }

    /* ── How it works ────────────────────────────────── */
    .methodology {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      padding: 32px;
      margin: 40px 0;
    }

    .methodology h3 {
      margin: 0 0 8px;
      font-size: 1.15rem;
    }

    .methodology .subtitle {
      color: var(--color-muted);
      font-size: 0.9rem;
      margin: 0 0 28px;
    }

    .method-flow {
      display: flex;
      align-items: flex-start;
      flex-wrap: wrap;
      margin-bottom: 28px;
    }

    .method-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      flex: 1;
      min-width: 72px;
    }

    .method-icon {
      width: 46px;
      height: 46px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
    }

    .method-icon.gen    { background: #d1e7dd; }
    .method-icon.gate   { background: #ede7f6; }
    .method-icon.revise { background: #fff3cd; }
    .method-icon.done   { background: #cfe2ff; }

    .method-label {
      font-size: 0.68rem;
      font-weight: 600;
      color: var(--color-muted);
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .method-arrow {
      font-size: 1rem;
      color: var(--color-border);
      flex-shrink: 0;
      padding: 13px 2px 0;
    }

    .method-points {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .method-point {
      display: flex;
      gap: 12px;
      align-items: flex-start;
    }

    .method-point-icon {
      font-size: 1.1rem;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .method-point h4 {
      margin: 0 0 3px;
      font-size: 0.9rem;
    }

    .method-point p {
      margin: 0;
      font-size: 0.82rem;
      color: var(--color-muted);
      line-height: 1.5;
    }

    /* ── Section header ──────────────────────────────── */
    .section-title {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--color-muted);
      margin: 40px 0 10px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--color-border);
    }

    /* ── Workflow cards ───────────────────────────────── */
    .workflow-card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      padding: 16px 20px;
      margin-bottom: 10px;
      display: flex;
      align-items: flex-start;
      gap: 14px;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.15s, box-shadow 0.15s;
    }

    .workflow-card:hover {
      border-color: var(--color-primary);
      box-shadow: 0 2px 8px rgba(26,79,160,0.1);
      text-decoration: none;
    }

    .card-icon {
      width: 40px;
      height: 40px;
      background: var(--color-primary-light);
      color: var(--color-primary);
      border-radius: var(--radius);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      flex-shrink: 0;
    }

    .card-body { flex: 1; min-width: 0; }

    .card-title {
      font-weight: 700;
      font-size: 0.95rem;
      margin: 0 0 3px;
      color: var(--color-primary);
    }

    .card-desc {
      font-size: 0.82rem;
      color: var(--color-muted);
      margin: 0 0 8px;
    }

    .card-meta {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 0.72rem;
      background: #e9ecef;
      color: #495057;
    }

    .badge.badge-new {
      background: #d1e7dd;
      color: #0a3622;
      font-weight: 600;
    }

    .card-arrow {
      color: var(--color-muted);
      font-size: 1.1rem;
      flex-shrink: 0;
      padding-top: 10px;
    }

    /* ── Agency callout ──────────────────────────────── */
    .agency-callout {
      margin: 40px 0 0;
      padding: 20px 24px;
      background: #f0f4f8;
      border: 1px solid #c8d8e8;
      border-left: 4px solid var(--color-primary);
      border-radius: var(--radius);
      display: flex;
      align-items: flex-start;
      gap: 16px;
    }
    .agency-callout-icon {
      font-size: 1.4rem;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .agency-callout h4 {
      margin: 0 0 4px;
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--color-text);
    }
    .agency-callout p {
      margin: 0;
      font-size: 0.85rem;
      color: var(--color-muted);
      line-height: 1.5;
    }
    .agency-callout a { color: var(--color-primary); }

    /* ── Footer ──────────────────────────────────────── */
    .footer {
      margin: 48px 0 32px;
      padding-top: 24px;
      border-top: 1px solid var(--color-border);
      font-size: 0.8rem;
      color: var(--color-muted);
    }

    /* ── Responsive ──────────────────────────────────── */
    @media (max-width: 680px) {
      .method-points { grid-template-columns: 1fr; }
      .nav-links { display: none; }
      .nav-hamburger { display: block; }
      .howto-steps { flex-direction: column; align-items: flex-start; gap: 8px; }
      .howto-arrow { display: none; }
      .howto-step { flex-direction: row; text-align: left; }
    }
  </style>
  <script data-goatcounter="https://deanhewson.goatcounter.com/count"
          async src="//gc.zgo.at/count.js"></script>
</head>
