<div class="search-overlay" id="search-overlay" aria-hidden="true">
  <div class="search-modal" role="dialog" aria-modal="true" aria-label="Search">
    <div class="search-modal-top">
      <input
        type="search"
        id="overlay-search-input"
        class="overlay-search-input"
        placeholder="Search workflows and blocks…"
        autocomplete="off"
        spellcheck="false"
        aria-label="Search"
        aria-controls="search-results"
        aria-autocomplete="list"
        aria-haspopup="listbox"
        aria-activedescendant=""
      />
      <kbd class="search-esc-hint">ESC</kbd>
    </div>
    <div class="search-status" id="search-status"></div>
    <ul class="search-results" id="search-results" role="listbox"></ul>
  </div>
</div>

<style>
  .search-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 400;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
  }
  .search-overlay.is-open { display: flex; }

  .search-modal {
    background: white;
    border-radius: 10px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    width: 100%;
    max-width: 560px;
    margin: 0 20px;
    overflow: hidden;
  }

  .search-modal-top {
    display: flex;
    align-items: center;
    border-bottom: 1px solid #dee2e6;
    padding: 0 16px;
  }

  .overlay-search-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 1.05rem;
    font-family: inherit;
    padding: 18px 12px 18px 0;
    background: transparent;
  }

  .search-esc-hint {
    font-size: 0.72rem;
    background: #f1f3f5;
    border: 1px solid #dee2e6;
    border-radius: 4px;
    padding: 2px 6px;
    color: #868e96;
    font-family: inherit;
  }

  .search-status {
    font-size: 0.82rem;
    color: #868e96;
    padding: 0 16px;
    min-height: 2rem;
    display: flex;
    align-items: center;
  }

  .search-results {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 360px;
    overflow-y: auto;
  }

  :global(.search-results a) {
    display: block;
    padding: 12px 16px;
    border-bottom: 1px solid #f1f3f5;
    text-decoration: none;
    color: #212529;
    transition: background 0.1s;
  }
  :global(.search-results a:hover),
  :global(.search-results li[aria-selected="true"] a) { background: #f8f9fa; }

  :global(.result-name) { font-weight: 600; font-size: 0.9rem; color: #170a1c; display: block; }
  :global(.result-meta) { font-size: 0.78rem; color: #868e96; margin-top: 2px; display: block; }

  :global(.result-type-badge) {
    font-size: 0.65rem;
    background: #ede9fe;
    color: #5b21b6;
    padding: 1px 5px;
    border-radius: 8px;
    margin-left: 5px;
    vertical-align: middle;
    font-weight: 600;
  }
</style>

<script>
  const overlay = document.getElementById('search-overlay');
  const input = document.getElementById('overlay-search-input') as HTMLInputElement | null;
  const resultsList = document.getElementById('search-results');
  const statusEl = document.getElementById('search-status');

  if (!overlay || !input || !resultsList || !statusEl) {
    console.warn('SearchOverlay: missing DOM elements');
  }

  let fuseInstance: any = null;
  let selectedIndex = -1;
  let isLoadingFuse = false;
  let lastFocusedElement: HTMLElement | null = null;

  function escapeHtml(str: string): string {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  async function ensureFuse() {
    if (fuseInstance) return true;
    if (isLoadingFuse) return false;
    if (!(window as any).Fuse) {
      if (statusEl) statusEl.textContent = 'Search unavailable.';
      return false;
    }
    isLoadingFuse = true;
    if (statusEl) statusEl.textContent = 'Loading…';
    try {
      const res = await fetch('/search-index.json');
      if (!res.ok) throw new Error('network error');
      const data = await res.json();
      fuseInstance = new (window as any).Fuse(data, {
        keys: [
          { name: 'name', weight: 3 },
          { name: 'search_text', weight: 1 },
          { name: 'tags', weight: 2 },
          { name: 'domain_label', weight: 1.5 },
        ],
        threshold: 0.4,
        distance: 100,
        includeScore: true,
        minMatchCharLength: 2,
      });
      if (statusEl) statusEl.textContent = '';
      isLoadingFuse = false;
      return true;
    } catch {
      if (statusEl) statusEl.textContent = 'Search unavailable.';
      isLoadingFuse = false;
      return false;
    }
  }

  function openOverlay() {
    if (!overlay || !input) return;
    lastFocusedElement = document.activeElement as HTMLElement;
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    input.value = '';
    if (resultsList) resultsList.innerHTML = '';
    if (statusEl) statusEl.textContent = '';
    selectedIndex = -1;
    input.setAttribute('aria-activedescendant', '');
    input.focus();
    ensureFuse(); // pre-warm
  }

  function closeOverlay() {
    if (!overlay) return;
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    lastFocusedElement?.focus();
    lastFocusedElement = null;
  }

  window.addEventListener('open-search', openOverlay);

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      overlay?.classList.contains('is-open') ? closeOverlay() : openOverlay();
    }
    if (e.key === 'Escape' && overlay?.classList.contains('is-open')) closeOverlay();
  });

  // Close on backdrop click
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeOverlay();
  });

  // Search on input
  let searchTimer: ReturnType<typeof setTimeout> | null = null;
  input?.addEventListener('input', () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(async () => {
      if (!input) return;
      const q = input.value.trim();
      if (!q) {
        if (resultsList) resultsList.innerHTML = '';
        input.setAttribute('aria-activedescendant', '');
        selectedIndex = -1;
        return;
      }
      const ready = await ensureFuse();
      if (!ready || !resultsList) return;
      const results = fuseInstance.search(q).slice(0, 8);
      selectedIndex = -1;
      input.setAttribute('aria-activedescendant', '');
      resultsList.innerHTML = results.map((r: any, i: number) => {
        const isBlock = r.item.type === 'block';
        const meta = isBlock
          ? `${escapeHtml(r.item.domain_label || 'Building Block')} · ${escapeHtml(r.item.block_type_label ?? r.item.block_type ?? '')}`
          : `${escapeHtml(r.item.domain_label)} · ${escapeHtml(r.item.complexity)} · ${escapeHtml(r.item.estimated_time)}`;
        const typeTag = isBlock
          ? ` <span class="result-type-badge">Block</span>`
          : '';
        return `
          <li role="option" id="search-result-${i}" aria-selected="false">
            <a href="${escapeHtml(r.item.url)}" data-result>
              <span class="result-name">${escapeHtml(r.item.name)}${typeTag}</span>
              <span class="result-meta">${meta}</span>
            </a>
          </li>
        `;
      }).join('');
    }, 150);
  });

  // Keyboard navigation
  input?.addEventListener('keydown', (e) => {
    if (!resultsList || !input) return;
    const items = resultsList.querySelectorAll<HTMLAnchorElement>('a[data-result]');
    if (!items.length) return;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      selectedIndex = Math.max(selectedIndex - 1, -1);
    } else if (e.key === 'Enter') {
      if (selectedIndex >= 0 && items[selectedIndex]) {
        closeOverlay();
        items[selectedIndex].click();
      }
      return;
    } else return;

    items.forEach((item, i) => {
      const li = item.closest('li');
      if (li) li.setAttribute('aria-selected', i === selectedIndex ? 'true' : 'false');
    });
    if (selectedIndex >= 0) {
      items[selectedIndex].scrollIntoView({ block: 'nearest' });
      input.setAttribute('aria-activedescendant', `search-result-${selectedIndex}`);
    } else {
      input.setAttribute('aria-activedescendant', '');
    }
  });
</script>
